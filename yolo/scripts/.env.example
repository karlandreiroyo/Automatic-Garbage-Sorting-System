# Copy to .env in this folder (same directory as ws_url.py).

# local | deployed — switches URL without code changes
MODE=local

# --- LOCAL (MODE=local) ---
WS_HOST=localhost
WS_PORT=3001

# --- DEPLOYED (MODE=deployed) — use your Railway *ws-server* public URL (wss://) ---
# WS_URL=wss://your-websocket-service.up.railway.app
# Optional fallback host from site URL (https -> wss same host; only if WS is on that host):
# NUTRIBIN_APP_URL=https://automatic-garbage-sorting-system-production.up.railway.app
